[gd_scene format=3 uid="uid://bpno04cqaffpc"]

[sub_resource type="Shader" id="Shader_sky"]
code = "shader_type sky;

uniform vec3 sky_top_color : source_color = vec3(0.32, 0.54, 0.66);
uniform vec3 sky_horizon_color : source_color = vec3(0.67, 0.79, 0.82);
uniform vec3 ground_bottom_color : source_color = vec3(0.18, 0.33, 0.44);
uniform vec3 ground_horizon_color : source_color = vec3(0.54, 0.70, 0.76);
uniform vec3 cloud_color : source_color = vec3(0.65, 0.68, 0.72);
uniform sampler2D cloud_texture;

void sky() {
	float v = EYEDIR.y;
	float up = max(v, 0.0);
	float down = max(-v, 0.0);
	
	vec3 sky = mix(sky_horizon_color, sky_top_color, up);
	vec3 ground = mix(ground_horizon_color, ground_bottom_color, down);
	vec3 color = v > 0.0 ? sky : ground;
	
	if (v > 0.0) {
		vec2 uv1 = EYEDIR.xz / (v + 0.12);
		vec2 uv2 = EYEDIR.xz / (v + 0.25);
		
		float c1 = texture(cloud_texture, uv1 * 0.12).a;  // <-- use alpha
		c1 = smoothstep(0.3, 0.7, c1);
		
		float c2 = texture(cloud_texture, uv2 * 0.07).a;
		c2 = smoothstep(0.4, 0.65, c2);
		
		float cloud = max(c1, c2 * 0.9);
		float fade = smoothstep(0.0, 0.4, up);
		
		color = mix(color, cloud_color, cloud * fade * 0.8);
	}
	
	COLOR = color * 0.92; // slight darkening to enhance contrast
}"

