                <UserObject label="# entity_pool.gd&#xa;extends Node&#xa;&#xa;&#xa;var pools: Dictionary = {}  # scene_path -&gt; Array of instances&#xa;&#xa;&#xa;func get_entity(scene_path: String) -&gt; Node3D:&#xa;    if pools.has(scene_path) and pools[scene_path].size() &gt; 0:&#xa;        var instance = pools[scene_path].pop_back()&#xa;        instance.show()&#xa;        return instance&#xa;    else:&#xa;        return load(scene_path).instantiate()&#xa;&#xa;&#xa;func return_entity(entity: Node3D, scene_path: String):&#xa;    entity.hide()&#xa;    entity.position = Vector3.ZERO&#xa;    # reset all components via signals&#xa;    entity.reset.emit()&#xa;    if not pools.has(scene_path):&#xa;        pools[scene_path] = []&#xa;    pools[scene_path].append(entity)" link="# entity_pool.gd&#xa;extends Node&#xa;&#xa;&#xa;var pools: Dictionary = {}  # scene_path -&gt; Array of instances&#xa;&#xa;&#xa;func get_entity(scene_path: String) -&gt; Node3D:&#xa;    if pools.has(scene_path) and pools[scene_path].size() &gt; 0:&#xa;        var instance = pools[scene_path].pop_back()&#xa;        instance.show()&#xa;        return instance&#xa;    else:&#xa;        return load(scene_path).instantiate()&#xa;&#xa;&#xa;func return_entity(entity: Node3D, scene_path: String):&#xa;    entity.hide()&#xa;    entity.position = Vector3.ZERO&#xa;    # reset all components via signals&#xa;    entity.reset.emit()&#xa;    if not pools.has(scene_path):&#xa;        pools[scene_path] = []&#xa;    pools[scene_path].append(entity)" id="cPyHHRRV4SVkm0UKQQWR-2">
