    <diagram id="GhG0tcqK5gItKIjx0V8-" name="Level Design">
        <mxGraphModel dx="2686" dy="781" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--1" value="level design is more about functuinality and gameplay, whereas art is about a coherent, attractive and usualy realistic image." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="-740" y="500" width="680" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--5" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
                    <mxGeometry x="-720" y="710" width="557.56" height="310" as="geometry"/>
                </mxCell>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--6" value="Plan your levels ahead of design, incorporate new mechanics on different levels with varying art/theme and difficulty" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="-750" y="640" width="640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--7" value="https://www.youtube.com/watch?v=XK-yTqYAD-c#t=1860" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="-615" y="668" width="330" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--10" value="&lt;ul style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); font-size: 14px;&quot;&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;Use graybox&lt;/li&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;Do not get emotionally attached to a level&lt;/li&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;Do not early polish&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=default;labelBackgroundColor=default;labelBorderColor=default;" parent="1" vertex="1">
                    <mxGeometry x="-760" y="530" width="320" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--11" value="&lt;font style=&quot;font-size: 16px;&quot; face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;text-align: start; white-space: pre-wrap;&quot;&gt;John Romero&#39;s Level Design Tips/Rules:&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;ul style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot; face=&quot;Helvetica&quot;&gt;Use a lot of contrast (light vs dark, open vs cramped)&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot; face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;box-sizing: inherit; border: 0px; font-style: italic; margin: 0px; outline: 0px; padding: 0px; vertical-align: baseline; color: rgba(51, 51, 51, 0.7); text-align: start; text-wrap-mode: wrap; background-color: rgb(255, 255, 255);&quot;&gt;If a player can see it, they should be able to somehow get there&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;box-sizing: inherit; border: 0px; margin: 0px; outline: 0px; padding: 0px; vertical-align: baseline; text-align: start; background-color: rgb(255, 255, 255); color: rgba(51, 51, 51, 0.7);&quot;&gt;&lt;span style=&quot;font-size: 16px; text-wrap-mode: wrap;&quot;&gt;&lt;i&gt;Have a secret area on every level&lt;/i&gt;&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;box-sizing: inherit; border: 0px; margin: 0px; outline: 0px; padding: 0px; vertical-align: baseline; text-align: start; background-color: rgb(255, 255, 255); color: rgba(51, 51, 51, 0.7);&quot;&gt;&lt;i style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; text-wrap-mode: wrap;&quot;&gt;Make the level flow so the player will revisit areas several times so they will better understand the 3D space of the level&lt;/span&gt;&lt;/i&gt;&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;box-sizing: inherit; border: 0px; margin: 0px; outline: 0px; padding: 0px; vertical-align: baseline; text-align: start; background-color: rgb(255, 255, 255); color: rgba(51, 51, 51, 0.7);&quot;&gt;&lt;i style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; text-wrap-mode: wrap;&quot;&gt;Create easily recognizable landmarks in several places for easier navigation&lt;/span&gt;&lt;/i&gt;&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=light-dark(#000000,#FFFFFF);labelBackgroundColor=default;labelBorderColor=default;fontStyle=1;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="-1560" y="380" width="900" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--12" value="&lt;div style=&quot;text-align: start;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212)); font-size: 16px; white-space: pre-wrap;&quot;&gt;Have different paths (with different types of difficulty) to the same final destination?&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=light-dark(#000000,#FFFFFF);labelBackgroundColor=default;labelBorderColor=default;fontStyle=1;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="-1520" y="690" width="650" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="9QRbBeYFw8TzBSCk2BS--13" value="These rules are project based, lead designer should define them to be followed for the whole game" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" parent="1" vertex="1">
                    <mxGeometry x="-1470" y="300" width="720" height="30" as="geometry"/>
                </mxCell>
                <UserObject label="Paidia = playfulness&lt;div&gt;https://www.youtube.com/watch?v=nkLmjJK3vOw#t=2002&lt;/div&gt;" link="https://www.youtube.com/watch?v=nkLmjJK3vOw#t=2002" id="d1yNhCEfxE1hSEj8sAEF-1">
                    <mxCell style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Helvetica;fontSize=16;fontColor=default;" parent="1" vertex="1">
                        <mxGeometry x="-1325" y="90" width="430" height="50" as="geometry"/>
                    </mxCell>
                </UserObject>
                <mxCell id="a0VGIJmVv3KP0jg-1Liv-3" value="&lt;ul&gt;&lt;li&gt;There should be customization&lt;/li&gt;&lt;li&gt;Players should feel they left a mark on the game somehow&lt;/li&gt;&lt;/ul&gt;" style="whiteSpace=wrap;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=16;fontColor=default;autosize=1;fillColor=default;gradientColor=none;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-1340" y="170" width="480" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="hE-B6rHY12C3RO2b7fN3-1" value="Your first level should be your last!" style="whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-720" y="340" width="120" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="MTt8x0mFtMwIw3jyyeLn-2" value="Every 5-10 minutes, introduce a new mechanic" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-570" y="120" width="120" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="MTt8x0mFtMwIw3jyyeLn-6" value="" style="edgeStyle=none;html=1;" parent="1" source="MTt8x0mFtMwIw3jyyeLn-3" target="MTt8x0mFtMwIw3jyyeLn-5" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="MTt8x0mFtMwIw3jyyeLn-3" value="First 5 minutes of the game should answer the question: What am I doing? &amp;gt; How am I doing it?" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-420" y="70" width="120" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="MTt8x0mFtMwIw3jyyeLn-5" value="Next 5 minutes: Why am I doing it? What is end goal?" style="whiteSpace=wrap;html=1;rounded=1;" parent="1" vertex="1">
                    <mxGeometry x="-420" y="190" width="120" height="60" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
