; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Space Toilet"
run/main_scene="uid://dlvcb7vmtq1lo"
config/features=PackedStringArray("4.7", "Forward Plus")
run/max_fps=1000
config/icon="res://scr/icon.svg"

[audio]

buses/default_bus_layout="uid://plxel2xf671u"

[autoload]

PauseManager="*res://scr/util/autoload/pause_manager.gd"
GameEvents="*res://scr/util/autoload/game_events.gd"
SoundManager="*uid://c6aviitsw1wa"
GoapWorldState="*uid://clan8pwdcjgaj"
HitStopManager="*res://scr/util/autoload/hit_stop_manager.gd"
TestGoapConsistency="*res://tests/goap.gd"
TestAudio="*uid://cxi4v122jd7b6"
GraphBuilder="*res://scr/util/autoload/goap_graph_builder.gd"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1
shapes/collision/shape_color=Color(0, 0.6, 0.701961, 1)

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/subwindows/embed_subwindows=false
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/GDQuest_GDScript_formatter/plugin.cfg")

[file_customization]

folder_colors={
"res://icons/": "green",
"res://scr/common/animation/": "yellow",
"res://scr/documentation/": "gray",
"res://scr/entity/": "yellow",
"res://scr/goap/": "pink",
"res://scr/player/": "yellow",
"res://scr/player/combat/": "gray",
"res://scr/sound/": "blue",
"res://scr/ui/": "green",
"res://scr/ui/debug/": "gray",
"res://scr/util/": "gray",
"res://scr/world_asset/": "orange",
"res://scr/world_map/": "orange"
}

[filesystem]

import/fbx/enabled=true

[global_group]

enemy=""

