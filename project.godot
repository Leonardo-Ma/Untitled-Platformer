; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Space Toilet"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=240
config/icon="res://icon.svg"

[autoload]

PauseManager="*res://scr/util/autoload/pause_manager.gd"
Attributes="*res://scr/util/autoload/player_attributes.gd"
Globals="*res://scr/util/autoload/globals.gd"
WorldState="*res://scr/goap/world_state.gd"
HitStopManager="*res://scr/util/autoload/hit_stop_manager.gd"
TestGoapConsistency="*res://tests/goap.gd"
GraphBuilder="*res://scr/util/autoload/goap_graph_builder.gd"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1
shapes/collision/shape_color=Color(0, 0.6, 0.701961, 1)

[display]

window/subwindows/embed_subwindows=false
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/GDQuest_GDScript_formatter/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

[file_customization]

folder_colors={
"res://icons/": "green",
"res://scr/common/animations/": "yellow",
"res://scr/debug/": "gray",
"res://scr/documentation/": "gray",
"res://scr/entity/": "yellow",
"res://scr/goap/": "pink",
"res://scr/player/": "yellow",
"res://scr/player/combat/": "gray",
"res://scr/sound/": "blue",
"res://scr/ui/": "green",
"res://scr/util/": "gray",
"res://scr/world_asset/": "orange"
}

[filesystem]

import/fbx/enabled=true

[global_group]

enemy=""

[importer_defaults]

scene={
"_subresources": {
"nodes": {
"PATH:tile_003": {
"generate/physics": true,
"physics/mask": 11
}
}
},
"animation/fps": 30,
"animation/import": true,
"animation/import_rest_as_RESET": false,
"animation/remove_immutable_tracks": true,
"animation/trimming": true,
"fbx/allow_geometry_helper_nodes": false,
"fbx/embedded_image_handling": 1,
"fbx/importer": 0,
"fbx/naming_version": 2,
"import_script/path": "uid://bufuiy4e3leva",
"materials/extract": 0,
"materials/extract_format": 0,
"materials/extract_path": "",
"meshes/create_shadow_meshes": true,
"meshes/ensure_tangents": true,
"meshes/force_disable_compression": false,
"meshes/generate_lods": true,
"meshes/light_baking": 1,
"meshes/lightmap_texel_size": 0.2,
"nodes/apply_root_scale": true,
"nodes/import_as_skeleton_bones": false,
"nodes/root_name": "",
"nodes/root_scale": 1.0,
"nodes/root_script": null,
"nodes/root_type": "",
"nodes/use_name_suffixes": true,
"nodes/use_node_type_suffixes": true,
"skins/use_named_skins": true
}

